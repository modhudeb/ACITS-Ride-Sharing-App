# Root-level catch-all - backend/ and frontend/ each keep their own
# more specific .gitignore; this covers anything that can appear at the
# repo root or in either subtree regardless of tooling.

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Editors
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo

# Env / secrets
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
serviceAccountKey.json

# Android release-signing key and its passwords - Play Store requires the
# SAME key for every future update of an app, so a leaked one can't just be
# rotated like any other credential (also mirrored in frontend/android/
# .gitignore, which is where these would actually be generated).
*.jks
*.keystore
key.properties

# Dependencies / build output
node_modules/
dist/
dist-ssr/
build/

# Python
__pycache__/
*.pyc
.venv/
venv/
*.db
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# JS tooling caches
.eslintcache

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Editor/merge-conflict backup files
*.orig
*.bak
*.tmp

# Claude Code local settings
.claude/
