# Firebase web app config (Project settings > General > Your apps, in the Firebase console)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Mapbox access token (map rendering + destination search). A single default
# public token is fine for testing/learning - see backend/.env.example for the
# matching server-side token used for route/fare calculation.
VITE_MAPBOX_TOKEN=

# Only needed if your Firestore database's ID isn't the reserved "(default)" -
# e.g. if it was created via the Google Cloud Console's Firestore setup flow
# instead of Firebase Console's "Create database" button, it may get a literal
# name like "default" instead. Check: Firebase Console > Firestore Database.
VITE_FIRESTORE_DATABASE_ID=
