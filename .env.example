# Variables read by docker-compose.yml. Copy to .env in the same directory
# on the deployment server. (Backend secrets live in backend/.env instead.)

# The public hostname Caddy serves + gets HTTPS certificates for.
# e.g. a free DuckDNS subdomain pointed at the server's Elastic IP.
# Use ":80" for plain-HTTP local testing.
SITE_ADDRESS=yourname.duckdns.org

# Mapbox public (pk.) token, baked into the web bundle at build time.
VITE_MAPBOX_TOKEN=pk.your-mapbox-public-token
