ENV=development

# Postgres connection string - a free Neon (neon.tech) project works well and
# uses the same connection string in dev and in production (no re-migration
# needed at deploy time). SQLAlchemy dialect prefix required: postgresql+psycopg://
DATABASE_URL=postgresql+psycopg://user:password@host/dbname?sslmode=require

# Signs/verifies session tokens (see core/security.py) - anyone holding this
# can forge a token for any account, so treat it like a database password.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-to-a-random-secret

# Mapbox access token (Directions API). A single default public token is fine
# for testing/learning; use a separate, more restricted token for production.
MAPBOX_TOKEN=your-mapbox-token

# Comma-separated list of origins allowed to call this API. https://localhost
# and http://localhost are the Capacitor Android WebView's origin - needed
# for the wrapped APK build, not just the Vite dev server.
CORS_ORIGINS=http://localhost:5173,https://localhost,http://localhost

# Credentials for the /admin login gate (frontend/src/views/admin/AdminLogin.jsx).
# The backing Postgres account row is created automatically on first
# successful login - no setup script needed. Change these for anything
# beyond local testing.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Used to build the link inside password-reset emails.
FRONTEND_BASE_URL=http://localhost:5173

# Optional - password-reset emails just log the reset link to the server
# console when SMTP_HOST is unset (fine for local dev). Set these to
# actually deliver mail in production.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=no-reply@yourdomain.com

# After running the Alembic migration (`alembic upgrade head`), run
# `python seed_demo_data.py` to create the admin/passenger/driver demo
# accounts above plus a default fare_rules row. Safe to re-run.
