ENV=development

# Firebase project id (from Firebase console)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Local dev: path to a downloaded service account key JSON file
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Deployed environments: paste the full service account JSON as a single line instead
# FIREBASE_SERVICE_ACCOUNT_JSON={"type": "service_account", ...}

# Only needed if your Firestore database's ID isn't the reserved "(default)" -
# e.g. if it was created via the Google Cloud Console's Firestore setup flow
# instead of Firebase Console's "Create database" button, it may get a literal
# name like "default" instead. Check: Firebase Console > Firestore Database.
FIRESTORE_DATABASE_ID=

# Mapbox access token (Directions API). A single default public token is fine
# for testing/learning; use a separate, more restricted token for production.
MAPBOX_TOKEN=your-mapbox-token

# Comma-separated list of origins allowed to call this API
CORS_ORIGINS=http://localhost:5173

# Credentials for the /admin login gate (frontend/src/views/admin/AdminLogin.jsx).
# The backing Firebase account is created automatically on first successful
# login - no setup script needed. Change these for anything beyond local testing.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
